# Ignore all files in the node_modules directory
node_modules/

# Ignore build output directories
dist/
build/

# Ignore environment variables file (never commit secrets)
.env
.env.*
!.env.example

# Ignore OS-specific files
.DS_Store
Thumbs.db

# Ignore IDE/editor configuration files
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Ignore log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Ignore testing artifacts
coverage/
*.test.*

# Ignore temporary files
*.tmp

# Ignore package manager cache directories
.npm/
.yarn/
.pnpm-cache/

# Ignore Tauri specific files if applicable
src-tauri/target/

# Ignore Vite specific files if applicable
.vite/

# Ignore WXT specific files if applicable
.wxt/
